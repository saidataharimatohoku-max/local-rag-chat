# Provider: "local" (Ollama, no cloud) or "azure". Leave unset to auto-detect
# (uses Azure when Azure OpenAI is configured, otherwise local Ollama).
PROVIDER=local

# Local provider (Ollama) — no account or keys needed
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Azure OpenAI (only needed when PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search (only needed when PROVIDER=azure)
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-key
AZURE_SEARCH_INDEX=knowledge-index

# Retrieval
RAG_TOP_K=4
